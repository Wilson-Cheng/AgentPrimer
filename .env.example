# Required for production deployments.
# Generate with: openssl rand -hex 32
AGENT_PRIMER_SECRET=<Your 64-character random secret>

# Optional: install exa mcp
# npx -y exa-mcp-server
EXA_API_KEY=<Your EXA API Key>

# Optional: install context7
# npx -y @upstash/context7-mcp@latest
CONTEXT7_API_KEY=<Your Context7 API key>

# Optional: code-server password for docker-compose deployments
CODE_SERVER_PASSWORD=<Change this before deploying code-server>

